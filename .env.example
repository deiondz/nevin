MONGODB_URI="mongodb://localhost:27017/nevin"
MONGODB_MAX_POOL_SIZE="10"
BETTER_AUTH_SECRET="replace-with-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:3000"

# App branding (used in auth email templates). Defaults to Nevin.
# APP_NAME="Nevin"

# ZeptoMail transactional email. When both TOKEN and FROM_EMAIL are set,
# emails are sent via ZeptoMail; otherwise they are logged to the console.
# ZEPTOMAIL_TOKEN=""
# ZEPTOMAIL_FROM_EMAIL="noreply@yourdomain.com"
# ZEPTOMAIL_FROM_NAME="Nevin"

# Optional Postgres path. Only needed if src/lib/db.ts is imported.
# DATABASE_URL="postgresql://user:password@localhost:5432/nevin"

# Optional social providers. Add only the providers you want to expose.
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
